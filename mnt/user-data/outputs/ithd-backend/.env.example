// backend/.env.example
# Database Configuration
DB_HOST=your-sql-server-host
DB_USER=your-db-user
DB_PASS=your-db-password
DB_NAME=your-database-name

# JWT Configuration
JWT_SECRET=your-very-secret-key-change-this-in-production

# Email Configuration
# Option 1: Daikin Internal SMTP
SMTP_HOST=smtp.dci.daikin.co.jp
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=your-email@dci.daikin.co.jp
EMAIL_PASSWORD=your-email-password
EMAIL_FROM="IT Service Desk <your-email@dci.daikin.co.jp>"

# Option 2: Gmail (if using Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password (16 chars from Gmail security)
# EMAIL_FROM="IT Service Desk <your-email@gmail.com>"

# Option 3: Office 365/Outlook
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=your-email@outlook.com
# EMAIL_PASSWORD=your-password
# EMAIL_FROM="IT Service Desk <your-email@outlook.com>"

# Server Configuration
PORT=3000
NODE_ENV=development

# Daikin AD API
DAIKIN_API_URL=http://websrv01.dci.daikin.co.jp/BudgetCharts/BudgetRestService/api/authen
